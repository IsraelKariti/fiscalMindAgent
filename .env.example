# Postgres
DATABASE_URL=postgres://fiscalmind:fiscalmind@localhost:5432/fiscalmind

# Redis
REDIS_URL=redis://localhost:6379

# Gemini (Google AI Studio API key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Fallback model only — the admin dashboard's Settings tab picks the model at
# runtime (stored in app_settings); this applies while no model is saved there.
GEMINI_MODEL=gemini-2.5-flash

# Accountant's IANA timezone. Shown to the LLM as prompt context and used to
# convert its local `send_at` wall-clock answer into the UTC send time.
ACCOUNTANT_TIMEZONE=Asia/Jerusalem

# Web server port (must match ngrok's local target)
PORT=3000

# --- Multi-clone dev ports -------------------------------------------------
# Several clones of this repo can run their dev stacks side by side; give each
# clone unique values here (and matching DATABASE_URL / REDIS_URL /
# AZURE_STORAGE_CONNECTION_STRING for the infra host ports below).

# Vite dev server (GUI) port
GUI_PORT=5173

# Next.js dev server (landing page) port
LANDING_PORT=3100

# Host ports docker-compose publishes Postgres / Redis / Azurite on.
# DATABASE_URL, REDIS_URL and AZURE_STORAGE_CONNECTION_STRING must use these.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
AZURITE_HOST_PORT=10000

# Distinct docker-compose project name per clone (isolates containers+volumes)
COMPOSE_PROJECT_NAME=fiscalmind

# Reserved ngrok domain for this clone's tunnel (target = PORT above).
# Leave empty to skip starting ngrok in `npm run dev`.
NGROK_DOMAIN=
# ---------------------------------------------------------------------------

# Public base URL of the web process (no trailing slash) — used to build OAuth
# redirect URIs. http://localhost:3000 locally, https://app.<domain> in prod.
APP_BASE_URL=http://localhost:3000

# Web-application OAuth client (Google Cloud Console) for dashboard Google
# sign-in AND the "Connect Google" flow (customer_service agent reads picked
# Sheets/Docs with the drive.file scope). Register BOTH redirect URIs on it:
#   <APP_BASE_URL>/api/auth/google/callback
#   <APP_BASE_URL>/api/auth/google-drive/callback
# Also enable the Google Sheets API, Google Docs API and Google Picker API on
# the project, and add the .../auth/drive.file scope on the consent screen
# (non-sensitive — no verification review needed).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Browser API key (same Google Cloud project) for the Google Picker the
# accountant picks Sheets/Docs with. Empty = the Picker endpoints return 503.
GOOGLE_PICKER_API_KEY=
# The Google Cloud project *number* (IAM & Admin -> Settings). Ties the Picker
# to the OAuth client so drive.file covers the picked files.
GOOGLE_APP_ID=

# Signs the dashboard session cookie (min 16 chars). If unset, a random
# per-process secret is used and sessions reset on every web-server restart.
DASHBOARD_SESSION_SECRET=

# Encrypts secrets at rest in Postgres (client tax-portal credentials,
# Google/monday OAuth tokens) — AES-256-GCM, see src/crypto/secretBox.ts.
# Required. Generate with: openssl rand -base64 32
# Web and worker must share the same key. NEVER lose or rotate it casually:
# losing it makes the stored credentials unrecoverable (every accountant would
# have to re-connect Google/monday and re-import tax-portal credentials).
# After first setting it on an existing DB, run: npm run db:encrypt-secrets
SECRET_ENC_KEY=

# Comma-separated Google account emails granted the admin panel and user
# impersonation ("view as user") in the dashboard. Empty = no admins.
ADMIN_EMAILS=

# Resend (resend.com) — sends agent mail and receives inbound mail for the
# agent domain. API key from the Resend dashboard (needs sending access).
RESEND_API_KEY=

# Signing secret of the Resend webhook endpoint (Webhooks -> your endpoint),
# used to verify Svix signatures on POST /webhooks/resend. The endpoint URL is
# <APP_BASE_URL>/webhooks/resend (the ngrok URL in dev).
RESEND_WEBHOOK_SECRET=

# Domain agent mailboxes are allocated on: <name>@AGENT_EMAIL_DOMAIN.
# Must be verified for sending + receiving in Resend. A subdomain of the root
# domain — the root's MX records belong to Google Workspace (admin@ and other
# human mail), so Resend receiving lives on a subdomain with its own MX.
AGENT_EMAIL_DOMAIN=agents.fiscalmind.app

# monday.com app (widget embed). Create the app in the monday Developer Center,
# add a "Dashboard Widget" feature whose iframe URL is <public URL>/monday
# (https://<NGROK_DOMAIN>/monday in dev — run `npm run build:gui` first, the
# widget is served from web/dist), enable the me:read + boards:read scopes, and
# copy the app's Client Secret (Basic Information) here. It verifies the
# widget's sessionToken JWTs. Empty = the /api/monday endpoints return 503.
MONDAY_CLIENT_SECRET=

# Client ID of the same monday app (Basic Information, next to the secret).
# Needed only for the "Connect monday" OAuth flow that stores a server-side
# monday API token per accountant (customer_service agent reads workdocs +
# boards with it). Also register this OAuth redirect URL on the app and enable
# the docs:read scope:
#   <APP_BASE_URL>/api/auth/monday/callback
# Empty = the connect endpoints return 503.
MONDAY_CLIENT_ID=

# Twilio (twilio.com) — WhatsApp channel. Setup:
#   1. Give each agent instance its own dedicated number, either way:
#      - Admin panel "buy number": auto-purchases a US number, registers it as
#        a WhatsApp sender under TWILIO_WABA_ID and assigns it (needs
#        TWILIO_WABA_ID + TWILIO_WEBHOOK_URL below), or
#      - manually: register the number as a WhatsApp sender in the Twilio
#        console (Messaging -> Senders -> WhatsApp senders), then assign it via
#        the admin panel or POST /api/admin/wa-senders. For dev, the Twilio
#        WhatsApp sandbox number works the same way (join the sandbox from your
#        phone first).
#   2. Point the sender's inbound webhook at <public URL>/webhooks/twilio and
#      set TWILIO_WEBHOOK_URL to that exact URL (signatures cover the full
#      URL; in dev that's https://<NGROK_DOMAIN>/webhooks/twilio). The buy
#      flow sets the sender's webhook to this URL automatically.
#   3. Create utility Content Templates (Messaging -> Content Template Builder),
#      wait for WhatsApp approval, then register each via
#      POST /api/admin/wa-templates with its HX... Content SID.
# SID/token/webhook empty = WhatsApp features stay disabled.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_URL=
# WhatsApp Business Account the platform's senders live under (Twilio console
# -> Messaging -> WhatsApp senders shows it). Only needed for "buy number";
# the one-time WABA creation / Meta business verification stays manual.
TWILIO_WABA_ID=
# Display name new auto-provisioned senders register with on WhatsApp (must
# follow Meta's display-name guidelines). Default: FiscalMind.
#TWILIO_WA_SENDER_NAME=

# Signs the short-lived public /media/<token> URLs Twilio fetches when the agent
# sends a document over WhatsApp (min 16 chars). The blob container stays
# private; the token is an expiring capability for one file. Empty = sending a
# WhatsApp media message throws (the tax-authority 106 delivery needs this).
MEDIA_SIGNING_SECRET=

# --- Tax-authority 106 fetch (doc collector browser automation) ------------
# When true, uses a no-browser mock instead of driving real Chrome — every
# real login SMSes a real citizen, so iterate on the mock. Default false.
TAX_FETCH_MOCK=false
# Real fetches never run Chrome in the worker: they go through the
# browser-runner sidecar (src/browserRunner.ts), a separate process that holds
# NO platform secrets, so a compromised page can't reach DB/API credentials.
# Shared bearer token between worker and runner (min 16 chars; generate with:
# openssl rand -hex 32). Empty = `npm run dev` skips starting the runner and
# real fetches fail with a clear error; the mock needs neither.
BROWSER_RUNNER_TOKEN=
# Where the worker reaches the runner. Default http://localhost:4100 (dev);
# in prod the internal URL of the fiscalmind-browser container app.
#BROWSER_RUNNER_URL=http://localhost:4100
# Port the runner listens on. Default 4100.
#BROWSER_RUNNER_PORT=4100
# How long a live browser session waits for the client's OTP before it is
# closed and the fetch marked expired (ms). Default 600000 (10 min). Read by
# the worker (primary timer) and the runner (backstop reaper).
#TAX_FETCH_SESSION_TTL_MS=600000
# When set, the runner saves step screenshots here (dev only).
#TAX_FETCH_DEBUG_DIR=
# ---------------------------------------------------------------------------
