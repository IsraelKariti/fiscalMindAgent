# Postgres
DATABASE_URL=postgres://fiscalmind:fiscalmind@localhost:5432/fiscalmind

# Redis
REDIS_URL=redis://localhost:6379

# Gmail OAuth (Desktop app client, from Google Cloud Console)
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Where the interactive `npm run gmail:auth` flow stores the obtained tokens.
GMAIL_TOKEN_PATH=./secrets/gmail_token.json

# Pub/Sub push subscription target for Gmail push notifications, e.g.
# projects/<project-id>/topics/gmail-form106-notifications
GMAIL_PUBSUB_TOPIC=

# Expected audience for the Pub/Sub push subscription's OIDC token, i.e. the
# public ngrok URL of the webhook endpoint (https://<subdomain>.ngrok-free.app/webhooks/gmail)
PUBSUB_PUSH_AUDIENCE=

# Gemini (Google AI Studio API key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Accountant's timezone, used only for prompt context (send-time preference), never for scheduling math
ACCOUNTANT_TIMEZONE=America/New_York

# Web server port (must match ngrok's local target)
PORT=3000

# Dashboard GUI login (min 8 chars). Login is disabled until this is set.
DASHBOARD_PASSWORD=
# Signs the dashboard session cookie (min 16 chars). If unset, a random
# per-process secret is used and sessions reset on every web-server restart.
DASHBOARD_SESSION_SECRET=
