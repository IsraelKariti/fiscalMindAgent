{
  "name": "fiscalmind-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Node agent that emails a client to collect a form_106 document, with LLM-driven follow-up scheduling.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "tsx watch src/web.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:gui": "npm run dev --prefix web",
    "build": "tsc -p .",
    "build:gui": "npm run build --prefix web",
    "start:web": "node dist/src/web.js",
    "start:worker": "node dist/src/worker.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "cli:bootstrap": "tsx src/cli/bootstrapClient.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "ioredis": "5.10.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
