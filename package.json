{
  "name": "fiscalmind-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Node agent that emails clients to collect their required documents, with LLM-driven follow-up scheduling.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "docker compose up -d --wait && npm run db:migrate && concurrently -n web,worker,gui,landing,browser,ngrok -c blue,yellow,green,magenta,cyan,gray npm:dev:web npm:dev:worker npm:dev:gui npm:dev:landing npm:dev:browser-runner \"node scripts/devNgrok.mjs\"",
    "dev:web": "node --watch-path=./src --import tsx src/web.ts",
    "dev:worker": "node --watch-path=./src --import tsx src/worker.ts",
    "dev:browser-runner": "node scripts/devBrowserRunner.mjs",
    "dev:gui": "npm run dev --prefix web",
    "dev:landing": "node scripts/devLanding.mjs",
    "build": "tsc -p .",
    "build:gui": "npm run build --prefix web",
    "start:web": "node dist/src/web.js",
    "start:worker": "node dist/src/worker.js",
    "start:browser-runner": "node dist/src/browserRunner.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:encrypt-secrets": "tsx scripts/encryptSecrets.ts",
    "cli:bootstrap": "tsx src/cli/bootstrapClient.ts",
    "ship": "node scripts/ship.mjs",
    "sync": "node scripts/sync.mjs",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.33.0",
    "@google/genai": "^2.10.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.0",
    "ioredis": "5.10.1",
    "pg": "^8.13.1",
    "playwright": "^1.61.1",
    "resend": "^6.17.1",
    "svix": "^1.96.1",
    "twilio": "^6.0.2",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
